## 相机和图片选择

### UIImagePickerController 封装

```swift
struct ImagePicker: UIViewControllerRepresentable {
    @Binding var image: UIImage?
    @Binding var showUploadDialog: Bool
    
    func makeUIViewController(context: Context) -> UIImagePickerController {
        let picker = UIImagePickerController()
        picker.delegate = context.coordinator
        picker.sourceType = .camera
        return picker
    }
    
    func updateUIViewController(_ uiViewController: UIImagePickerController, context: Context) {}
    
    func makeCoordinator() -> Coordinator {
        Coordinator(self)
    }
    
    class Coordinator: NSObject, UIImagePickerControllerDelegate, UINavigationControllerDelegate {
        let parent: ImagePicker
        
        init(_ parent: ImagePicker) {
            self.parent = parent
        }
        
        func imagePickerController(_ picker: UIImagePickerController, didFinishPickingMediaWithInfo info: [UIImagePickerController.InfoKey : Any]) {
            if let image = info[.originalImage] as? UIImage {
                parent.image = image
                parent.showUploadDialog = true
            }
            picker.dismiss(animated: true)
        }
    }
}
```

### 使用图片选择器

```swift
@State private var showImagePicker = false
@State private var selectedImage: UIImage?

.sheet(isPresented: $showImagePicker) {
    ImagePicker(image: $selectedImage, showUploadDialog: $showUploadDialog)
}
```

## KMP 集成

### 调用共享代码

```swift
import Shared

// 使用共享的数据模型
let photo: Photo = ...

// 调用共享的服务
let result = try await photoService.uploadPhoto(
    photoData: kotlinByteArray,
    fileName: fileName,
    mimeType: mimeType,
    width: width,
    height: height
)
```

### 数据类型转换

```swift
// Swift Data 转 Kotlin ByteArray
let kotlinByteArray = KotlinByteArray(size: Int32(photoData.count))
for (index, byte) in photoData.enumerated() {
    kotlinByteArray.set(index: Int32(index), value: Int8(bitPattern: byte))
}

// Kotlin ByteArray 转 Swift Data
let data = Data(bytes: kotlinByteArray, count: Int(kotlinByteArray.size))
```

## 错误处理

### 异步错误处理

```swift
func loadData() {
    Task {
        do {
            let result = try await service.getData()
            // 处理成功
        } catch {
            print("Error: \(error)")
            // 显示错误提示
            toastMessage = "加载失败"
        }
    }
}
```

### Result 处理

```swift
let result = try await photoService.uploadPhoto(...)
if result.isSuccess {
    // 成功
    loadPhotos()
} else if let error = result.exceptionOrNull() {
    // 失败
    print("Error: \(error)")
}
```

## 最佳实践

1. **主线程更新**: 所有 UI 更新必须在主线程，使用 `@MainActor`
2. **状态管理**: 使用 `@Published` 和 `@State` 管理状态
3. **异步操作**: 使用 `Task { }` 处理异步操作
4. **资源管理**: 及时释放图片、网络资源
5. **错误处理**: 所有异步操作都要处理错误
6. **响应式设计**: 使用 `ResponsiveContainer` 适配不同设备
7. **主题支持**: 使用 `ThemedView` 支持深色模式

## 注意事项

- ⚠️ **不要在主线程执行耗时操作**: 使用 `Task` 或 `async/await`
- ⚠️ **ViewModel 生命周期**: 使用 `@StateObject` 创建，`@ObservedObject` 观察
- ⚠️ **内存管理**: SwiftUI 自动管理，但要注意循环引用
- ⚠️ **KMP 类型转换**: 注意 Swift 和 Kotlin 类型差异
